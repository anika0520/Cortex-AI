# ── Cortex Frontend — Environment Variables ───────────────────────────────────
# Copy to .env for local development. Never commit .env to git.
# On Vercel: set these in Project Settings → Environment Variables.
# VITE_ prefix is required — Vite only exposes vars with this prefix.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Enables "Sign in with Google" button.
# Steps:
#   1. console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Authorized JavaScript origins:
#        http://localhost:5173
#        https://your-app.vercel.app
#   4. Authorized redirect URIs (same as origins for SPA):
#        http://localhost:5173
#        https://your-app.vercel.app
VITE_GOOGLE_CLIENT_ID=

# ── Backend connection ────────────────────────────────────────────────────────
# Local dev (without Docker): http://localhost:8000
# Vercel production: full Render URL, e.g. https://cortex-backend.onrender.com
# Docker/nginx: leave empty "" — nginx proxies /api and /health to backend
VITE_API_BASE_URL=

# Agent credentials — must match backend EXPECTED_EMAIL and MY_SECRET
VITE_AGENT_EMAIL=you@example.com
VITE_AGENT_SECRET=your_secret_here

# ── Groq LLM (in-browser fallback — no backend needed) ───────────────────────
# Free at https://console.groq.com → API Keys
# SECURITY NOTE: this key is visible in the browser bundle.
# For production, leave empty and use the Python backend instead.
VITE_GROQ_API_KEY=gsk_your_groq_key_here
