# ── Cortex Backend — Environment Variables ────────────────────────────────────
# Copy to .env for local development. Never commit .env to git.
# On Render: set these in the dashboard under Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (at least one required) ─────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here       # https://console.groq.com
AIPIPE_API_KEY=                            # optional alternative LLM proxy
AIPIPE_BASE_URL=https://aipipe.org/openai/v1

# ── Agent credentials (must match frontend VITE_AGENT_EMAIL / VITE_AGENT_SECRET)
EXPECTED_EMAIL=you@example.com
MY_SECRET=your_secret_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:      http://localhost:3000,http://localhost:5173
# After deploy:   https://cortex-xyz.vercel.app,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by Render — only set manually for local overrides.
PORT=8000

# ── Debug ─────────────────────────────────────────────────────────────────────
CORTEX_DEBUG=false

# ── Playwright ────────────────────────────────────────────────────────────────
# Set to 1 on Render free tier to skip Chromium download (saves build time/RAM).
# The backend falls back to httpx for scraping — most tasks still work.
# Set to 0 (or omit) for full scraping capability.
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=0
